## Required (production)
# MySQL connection string (TiDB Serverless recommended)
# Example format:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/DB_NAME?sslaccept=strict"
DATABASE_URL=""

# Used to sign the session cookie token (must be set in production)
# Use a long random string (>= 32 chars recommended)
AUTH_SECRET=""

## Optional (convenience)
# Default admin seed used on first login attempt if user doesn't exist yet.
# If not set, defaults to admin@example.com / admin123
ADMIN_NAME="Super Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

